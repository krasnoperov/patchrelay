{
  "name": "patchrelay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "patchrelay": "dist/index.js"
  },
  "description": "Local control plane that turns selected Linear issues into controlled coding-agent sessions.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json && chmod +x dist/index.js && node scripts/write-build-info.mjs",
    "start": "node dist/index.js",
    "restart": "sudo systemctl restart patchrelay",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.1.1",
    "fastify": "^5.2.1",
    "fastify-raw-body": "^5.0.0",
    "node-pty": "^1.1.0",
    "pino": "^9.6.0",
    "pino-logfmt": "^1.1.3",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
