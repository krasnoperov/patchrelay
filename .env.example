# PatchRelay secrets and runtime overrides.
# Copy to `.env` or load via your process manager.

LINEAR_WEBHOOK_SECRET=replace-with-linear-webhook-secret
LINEAR_API_TOKEN=lin_api_replace_me
PATCHRELAY_WEBHOOK_PATH_SUFFIX=replace-with-long-random-path-segment

# Optional overrides
# PATCHRELAY_CONFIG=/home/alv/projects/patchrelay/config/patchrelay.local.yaml
# PATCHRELAY_DB_PATH=/home/alv/.local/share/patchrelay/patchrelay.sqlite
# PATCHRELAY_LOG_LEVEL=info
# PATCHRELAY_LOG_FILE=/var/log/patchrelay/patchrelay.log
