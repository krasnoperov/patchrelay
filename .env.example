# PatchRelay secrets and runtime overrides.
# Copy to `.env` or load via your process manager.

LINEAR_WEBHOOK_SECRET=replace-with-linear-webhook-secret
LINEAR_API_TOKEN=replace-with-linear-api-token

# Optional: protects the internal operator API when `operator_api.enabled: true`
# PATCHRELAY_OPERATOR_TOKEN=replace-with-random-operator-token

# Optional overrides
# PATCHRELAY_HOME=/opt/patchrelay
# PATCHRELAY_CONFIG=/opt/patchrelay/config/patchrelay.yaml
# PATCHRELAY_DB_PATH=/var/lib/patchrelay/patchrelay.sqlite
# PATCHRELAY_LOG_LEVEL=info
# PATCHRELAY_LOG_FILE=/var/log/patchrelay/patchrelay.log
