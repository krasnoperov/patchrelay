{
	email you@example.com
}

patchrelay.example.com {
	encode zstd gzip

	# Forward only the public ingress surface to a localhost PatchRelay instance
	# that is running under a systemd user service.

	@home path /
	handle @home {
		reverse_proxy 127.0.0.1:8787
	}

	@health path /health
	handle @health {
		reverse_proxy 127.0.0.1:8787
	}

	@ready path /ready
	handle @ready {
		reverse_proxy 127.0.0.1:8787
	}

	@linear_webhook {
		path /webhooks/linear
		method POST
	}
	handle @linear_webhook {
		reverse_proxy 127.0.0.1:8787
	}

	handle {
		respond "not found" 404
	}
}
