# Machine-level non-secret config for review-quill.
#
# Secrets should normally be stored via systemd-creds, for example:
#   /etc/credstore.encrypted/review-quill-webhook-secret.cred
#   /etc/credstore.encrypted/review-quill-github-app-pem.cred

# The App identity is used both for review-quill's GitHub API calls AND for the Codex
# review agent's git/gh: review-quill keeps a private gh config dir fresh (under the data
# dir) so the agent authenticates as review-quill[bot] via GH_CONFIG_DIR, never falling
# back to the host operator's personal gh/git credentials.
# Grant the App least privilege (read contents + pull requests, write checks/reviews).
REVIEW_QUILL_GITHUB_APP_ID=123456
# Optional if you want to pin one installation:
# REVIEW_QUILL_GITHUB_APP_INSTALLATION_ID=12345678
