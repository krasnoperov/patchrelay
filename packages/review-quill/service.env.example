# Machine-level non-secret config for review-quill.
#
# Secrets should normally be stored via systemd-creds, for example:
#   /etc/credstore.encrypted/review-quill-webhook-secret.cred
#   /etc/credstore.encrypted/review-quill-github-app-pem.cred

REVIEW_QUILL_GITHUB_APP_ID=123456
# Optional if you want to pin one installation:
# REVIEW_QUILL_GITHUB_APP_INSTALLATION_ID=12345678
