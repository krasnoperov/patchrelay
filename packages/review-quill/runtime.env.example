# Non-secret defaults for review-quill.
# In the shared PatchRelay ingress layout, review-quill usually lives under
# a path prefix on the same host as PatchRelay and merge-steward.

REVIEW_QUILL_PUBLIC_BASE_URL=https://patchrelay.example.com/review

# Optional overrides:
# REVIEW_QUILL_CONFIG_DIR=/home/your-user/.config/review-quill
# REVIEW_QUILL_STATE_DIR=/home/your-user/.local/state/review-quill
# REVIEW_QUILL_DATA_DIR=/home/your-user/.local/share/review-quill
# REVIEW_QUILL_DB_PATH=/home/your-user/.local/state/review-quill/review-quill.sqlite
# REVIEW_QUILL_BIND=127.0.0.1
# REVIEW_QUILL_PORT=8788
# REVIEW_QUILL_LOG_LEVEL=info
# To override the built-in gpt-5.5 default, set codex.model in review-quill.json.
# REVIEW_QUILL_CODEX_BASE_URL=http://127.0.0.1:8787
