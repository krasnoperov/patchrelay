# Machine-level non-secret config for merge-steward.
# Secrets belong to the service and should stay in systemd-creds:
#   /etc/credstore.encrypted/merge-steward-webhook-secret.cred
#   /etc/credstore.encrypted/merge-steward-github-app-pem.cred

# MERGE_STEWARD_GITHUB_APP_ID=123456
# MERGE_STEWARD_GITHUB_APP_INSTALLATION_ID=12345678

# Recommended GitHub App repository permissions:
#   Contents: Read and write
#   Pull requests: Read and write
#   Checks: Read and write
#   Metadata: Read-only
#   Administration: Read-only
#
# Contents:write is required for steward's fast-forward merge path.
# Administration:read is recommended so doctor/attach can discover branch rules
# and required checks without local gh fallback.
