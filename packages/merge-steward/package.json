{
  "name": "merge-steward",
  "version": "0.32.5",
  "description": "Serial merge queue for GitHub — rebase, CI-gate, and merge PRs one at a time",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krasnoperov/patchrelay.git",
    "directory": "packages/merge-steward"
  },
  "homepage": "https://github.com/krasnoperov/patchrelay/tree/main/packages/merge-steward#readme",
  "keywords": [
    "merge-queue",
    "github",
    "ci",
    "serial-merge",
    "rebase",
    "pull-request"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/sim",
    "!dist/memory-store.*",
    "runtime.env.example",
    "service.env.example",
    "infra/merge-steward.service"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "merge-steward": "dist/index.js"
  },
  "scripts": {
    "dev": "node --watch --experimental-transform-types src/index.ts",
    "prepack": "pnpm build",
    "build": "rm -rf dist && tsgo -p tsconfig.json && chmod +x dist/index.js",
    "start": "node dist/index.js serve",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "node --experimental-transform-types --test 'test/**/*.test.ts'",
    "test:scenarios": "node --experimental-transform-types --test 'test/scenarios/*.test.ts'",
    "test:property": "node --experimental-transform-types --test 'test/property/*.test.ts'"
  },
  "dependencies": {
    "fastify": "^5.10.0",
    "fastify-raw-body": "^5.0.0",
    "ink": "^7.1.0",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "7.0.0-dev.20260427.1",
    "fast-check": "^4.9.0",
    "isomorphic-git": "^1.38.6",
    "memfs": "^4.64.0"
  }
}
