# Non-secret defaults for merge-steward.
# Keep machine-level paths and the public webhook origin here.

MERGE_STEWARD_PUBLIC_BASE_URL=https://queue.example.com

# Optional overrides:
# MERGE_STEWARD_CONFIG_DIR=/home/your-user/.config/merge-steward
# MERGE_STEWARD_STATE_DIR=/home/your-user/.local/state/merge-steward
# MERGE_STEWARD_DATA_DIR=/home/your-user/.local/share/merge-steward
# MERGE_STEWARD_SYSTEMD_DIR=/etc/systemd/system
